{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Preview documentation (MkDocs)",
      "type": "shell",
      "command": "python3 -m mkdocs serve -f mkdocs.yml -a 127.0.0.1:8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "mkdocs",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving",
          "endsPattern": "Serving on http://127\\.0\\.0\\.1:8000"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Build documentation (MkDocs)",
      "type": "shell",
      "command": "python3 -m mkdocs build -f mkdocs.yml",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
